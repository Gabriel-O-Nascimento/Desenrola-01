{
  "enabled": true,
  "name": "Verificar Atualizações do Git",
  "description": "Antes de iniciar qualquer tarefa, verifica se o repositório local está sincronizado com o remoto (GitHub). Avisa se há commits novos para puxar ou commits locais para enviar.",
  "version": "1",
  "when": {
    "type": "preTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/verificar-atualizacao.sh",
    "timeout": 30
  }
}