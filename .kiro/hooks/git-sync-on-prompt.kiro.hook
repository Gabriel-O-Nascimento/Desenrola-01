{
  "enabled": true,
  "name": "Git Sync ao Iniciar Chat",
  "description": "Ao enviar a primeira mensagem no chat, verifica se o repositório está atualizado com o GitHub para evitar trabalhar em código desatualizado.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/verificar-atualizacao.sh",
    "timeout": 30
  }
}